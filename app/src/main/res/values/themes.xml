<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- MAIN THEME -->
    <style name="Theme.TechMate" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- 🔥 ĐỒNG BỘ MÀU -->
        <item name="colorPrimary">#28C8BE</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <item name="colorPrimaryContainer">#28C8BE</item>
        <item name="colorOnPrimaryContainer">#FFFFFF</item>

        <!-- Secondary -->
        <item name="colorSecondary">#10B981</item>
        <item name="colorOnSecondary">#FFFFFF</item>

        <!-- Background -->
        <item name="android:colorBackground">#F8FAFC</item>
        <item name="colorSurface">#FFFFFF</item>

        <!-- Text -->
        <item name="colorOnSurface">#1F2937</item>

        <!-- Container -->
        <item name="colorSecondaryContainer">#E0F2FE</item>
        <item name="colorOnSecondaryContainer">#1E40AF</item>

        <!-- Ripple -->
        <item name="colorControlHighlight">#28C8BE</item>

        <item name="colorAccent">#28C8BE</item>

    </style>


    <!-- 🔥 SPLASH THEME -->
    <style name="Theme.TechMate.Splash" parent="Theme.SplashScreen">

        <!-- 🔥 MÀU CHUẨN -->
        <item name="windowSplashScreenBackground">#28C8BE</item>

        <!-- logo -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo_tm</item>

        <!-- chuyển theme -->
        <item name="postSplashScreenTheme">@style/Theme.TechMate</item>

        <!-- delay -->
        <item name="windowSplashScreenAnimationDuration">1500</item>

    </style>

</resources>