<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="vn.edu.dlu.ctk47.techmate.HomeFragment"
        android:label="Home"/>

    <fragment
        android:id="@+id/detailFragment"
        android:name="vn.edu.dlu.ctk47.techmate.DetailFragment"
        android:label="Detail" />

    <fragment
        android:id="@+id/cartFragment"
        android:name="vn.edu.dlu.ctk47.techmate.CartFragment"
        android:label="Cart" />

    <fragment
        android:id="@+id/compareFragment"
        android:name="vn.edu.dlu.ctk47.techmate.CompareFragment"
        android:label="Compare" />

    <fragment
        android:id="@+id/checkoutFragment"
        android:name="vn.edu.dlu.ctk47.techmate.CheckoutFragment"
        android:label="Checkout" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="vn.edu.dlu.ctk47.techmate.ProfileFragment"
        android:label="Profile">
        <action
            android:id="@+id/action_profileFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
        <action
            android:id="@+id/action_profileFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="vn.edu.dlu.ctk47.techmate.LoginFragment"
        android:label="Login">
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="vn.edu.dlu.ctk47.techmate.RegisterFragment"
        android:label="Register" />

    <fragment
        android:id="@+id/settingsFragment"
        android:name="vn.edu.dlu.ctk47.techmate.SettingsFragment"
        android:label="Settings" />

</navigation>